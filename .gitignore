# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
design/archive/roi-labs-site.zip

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
# local dev server logs (may contain stack traces / request detail — never commit)
*.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel
.vercel-engine.json

# supabase local dev artifacts (keep config.toml + migrations tracked)
/supabase/.branches/
/supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts

# editor / agent caches (local-only)
.agents/
.claude/
.vscode/
.idea/

# stray artifacts
nul
skills-lock.json
images (*).jpg
# python bytecode cache (from the standalone-HTML generator scripts)
__pycache__/
*.pyc
# large media — don't commit screen recordings to git
*.mp4
*.mov

# scratch / local-only working media (WhatsApp exports, screen recordings)
demo assets/
# stale standalone export (regenerable)
design/pages/roi-engine-dashboard.html
# confidential business/legal material — never commit (note: pre-existing docs/* remain in history)
/docs/

# generated cockpit snapshots
cockpit-astrotime.html
astrotime-real-metrics.html
