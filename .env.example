# Supabase — used by /api/leads route to store contact-form submissions.
# Get these from https://supabase.com/dashboard/project/_/settings/api
# The publishable / anon key is safe to expose in the browser; RLS is what
# protects the leads table (insert-only for anon).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
