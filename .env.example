# Supabase — used by /api/leads route to store contact-form submissions.
# Get these from https://supabase.com/dashboard/project/_/settings/api
# The publishable / anon key is safe to expose in the browser; RLS is what
# protects the leads table (insert-only for anon).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# ROI Labs ENGINE (the 5-agent backend). All SERVER-ONLY — never NEXT_PUBLIC_*.
# The engine boots without these; each connector errors only when used, so you
# can deploy the code first and fill credentials last. Full setup: ENGINE.md.
# ============================================================================

# Supabase service-role key — bypasses RLS for the server-only engine_* tables.
# SUPABASE_URL falls back to NEXT_PUBLIC_SUPABASE_URL if unset.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — the agent brain.
ANTHROPIC_API_KEY=
# ENGINE_MODEL=claude-opus-4-8        # default; override to tune cost
# ENGINE_FAST_MODEL=claude-sonnet-4-6

# Admin bearer token for the /api/engine/* ops routes (fail-closed if unset).
# Use a long random string in production.
ENGINE_ADMIN_TOKEN=

# --- Safety rails (default to "spend nothing") ------------------------------
# Master kill-switch: "true" (default) simulates every mutation. Set to
# "false" only when you are ready to let approved changes hit the platforms.
ENGINE_DRY_RUN=true
# Hard global daily spend ceiling in cents. 0 (default) blocks ALL live spend.
ENGINE_GLOBAL_DAILY_SPEND_CAP_CENTS=0
# Hard ceiling on the daily spend ANY single mutation may authorize, in cents.
# Above this = rejected outright (not even approvable). 0 = disabled. Strongly
# recommended once live: a backstop against a fat-finger / injected budget.
ENGINE_MAX_SINGLE_MUTATION_SPEND_CENTS=0

# --- Google Ads (fill LAST — see ENGINE.md "Connecting Google") -------------
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=        # MCC id, digits only, no dashes
# GOOGLE_ADS_API_VERSION=v18

# --- Meta Marketing API (fill LAST — see ENGINE.md "Connecting Meta") -------
META_SYSTEM_USER_TOKEN=
# META_API_VERSION=v21.0

# --- Shopify (revenue source of truth; for ecommerce brands) ----------------
# Custom-app Admin API token (scope: read_orders). See ENGINE.md "Connecting Shopify".
SHOPIFY_STORE_DOMAIN=          # e.g. theastrotime.myshopify.com
SHOPIFY_ADMIN_TOKEN=          # shpat_...
# SHOPIFY_API_VERSION=2025-10
