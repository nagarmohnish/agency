{
  "name": "ROI Labs",
  "site": "https://roilabs.in",
  "brand": {
    "yellow": "#FACC15",
    "yellowDeep": "#EFC00A",
    "yellowHighlight": "#FFE05A",
    "goldText": "#8A6D00",
    "yellowGradient": "linear-gradient(95deg,#FFE05A,#FACC15 55%,#F2BE00)"
  },
  "palettes": {
    "aurora": {
      "description": "Marketing site — warm cream + ink + brand yellow",
      "bg": "#FCFBF7",
      "surface": "#FFFFFF",
      "surface2": "#FBF6E6",
      "ink": "#1A1710",
      "muted": "#6A6456",
      "faint": "#9C968A",
      "line": "#ECE7DA",
      "line2": "#F4F0E6",
      "green": "#1E9E6A",
      "error": "#CC4A3F"
    },
    "atlas": {
      "description": "ROI Engine — light mode, indigo working accent",
      "bg": "#F4F5F7",
      "panel": "#FFFFFF",
      "panel2": "#F6F7FB",
      "sidebar": "#1E1B4B",
      "ink": "#15171C",
      "ink2": "#6B7280",
      "ink3": "#9CA0A8",
      "border": "#ECEDF1",
      "accent": "#4F46E5",
      "accent2": "#4338CA",
      "accentTint": "#EEF0FE",
      "positive": "#16A34A",
      "negative": "#DC2626",
      "warning": "#B45309"
    },
    "terminal": {
      "description": "ROI Engine — dark mode, near-black with yellow accent",
      "bg": "#08090A",
      "panel": "#0C0D0F",
      "panel2": "#101113",
      "sidebar": "#0B0C0E",
      "ink": "#E6E7E9",
      "ink2": "#9A9DA4",
      "border": "#17181B",
      "accent": "#FACC15"
    }
  },
  "typography": {
    "display": { "family": "Sora", "weights": [600, 700, 800], "use": "marketing headlines" },
    "body": { "family": "Manrope", "weights": [400, 500, 600, 700], "use": "marketing body & UI" },
    "displayUI": { "family": "Space Grotesk", "weights": [600, 700], "use": "Engine headings, KPI values" },
    "bodyUI": { "family": "Hanken Grotesk", "weights": [400, 500, 600], "use": "Engine UI" },
    "mono": { "family": "JetBrains Mono", "weights": [400, 500, 600], "use": "metrics, tabular numbers, code" },
    "fallback": "system-ui, -apple-system, \"Segoe UI\", sans-serif"
  },
  "radii": { "sm": "6px", "md": "10px", "lg": "14px", "xl": "20px", "pill": "9999px" },
  "shadow": {
    "rest": "0 1px 2px rgba(20,22,28,.05)",
    "lift": "0 34px 70px -30px rgba(80,62,22,.30)"
  },
  "logo": {
    "rule": "\"ROI\" always brand yellow #FACC15; \"LABS\"/\"Engine\" neutral (black on light, white on dark)",
    "files": {
      "lightBg": "logos/roi-labs--light-bg.png",
      "darkBg": "logos/roi-labs--dark-bg.png",
      "blue": "logos/roi-labs--blue.png",
      "mark": "logos/roi-labs--mark.png"
    }
  },
  "accessibility": {
    "yellowOnWhite": "Never. #FACC15 fails WCAG as text on white — use #8A6D00 (gold text) or place yellow on a dark surface."
  }
}
